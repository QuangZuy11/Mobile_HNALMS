# Environment Variables Example
# Copy this file to .env and update with your values

# API Configuration
API_URL=http://localhost:9999/api
API_TIMEOUT=30000

# For production
# API_URL=https://your-production-domain.com/api

# For testing with real device (replace with your machine's IP)
# API_URL=http://192.168.x.x:9999/api
